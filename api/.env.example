# Server
ENVIRONMENT=development

# Database — PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://pixshift:password@localhost:5432/pixshift

# Redis — used for rate limiting in production
REDIS_URL=redis://localhost:6379

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Image processing limits
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_HOUR=100

# App version — shown in /health response
APP_VERSION=1.0.0
